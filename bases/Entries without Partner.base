views:
  - type: table
    name: Table
    filters:
      and:
        - partner.isEmpty()
        - file.ext == "md"
    order:
      - file.name
      - prev
      - section
      - extensions
      - partner
    sort:
      - property: prev
        direction: ASC
      - property: partner
        direction: ASC
      - property: tags
        direction: DESC
    columnSize:
      file.name: 269
      note.prev: 188
