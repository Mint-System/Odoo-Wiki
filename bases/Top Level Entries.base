formulas:
  Untitled: ""
views:
  - type: table
    name: Table
    filters:
      and:
        - prev == "./"
    order:
      - file.name
      - partner
      - prev
      - versions
    sort:
      - property: formula.Untitled
        direction: ASC
      - property: tags
        direction: DESC
    columnSize:
      note.partner: 263
